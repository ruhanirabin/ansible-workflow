Unattended-Upgrade::Allowed-Origins {
{% if ansible_distribution == 'Ubuntu' %}
    "${distro_id}:${distro_codename}-security";
{% elif ansible_distribution == 'Debian' %}
    "${distro_id}:${distro_codename}";
    "${distro_id}:${distro_codename}-security";
    "${distro_id}ESMApps:${distro_codename}-apps-security";
    "${distro_id}ESM:${distro_codename}-infra-security";
{% endif %}
{% for origin in unattended_upgrades_origins_merged | default([]) %}
    "{{ origin }}";
{% endfor %}
};

Unattended-Upgrade::Remove-Unused-Kernel-Packages "{{ unattended_upgrades_remove_unused_kernel | default(true) | string | lower }}";
Unattended-Upgrade::Remove-New-Unused-Dependencies "{{ unattended_upgrades_remove_new_unused_deps | default(true) | string | lower }}";
Unattended-Upgrade::Remove-Unused-Dependencies "{{ unattended_upgrades_remove_unused_deps | default(true) | string | lower }}";
Unattended-Upgrade::Automatic-Reboot "{{ unattended_upgrades_auto_reboot | default(true) | string | lower }}";
Unattended-Upgrade::Automatic-Reboot-Time "{{ unattended_upgrades_reboot_time | default('00:30') }}";
{% if unattended_upgrades_mail is defined and unattended_upgrades_mail | length > 0 %}
Unattended-Upgrade::Mail "{{ unattended_upgrades_mail }}";
{% if unattended_upgrades_mail_only_on_error is defined %}
Unattended-Upgrade::MailOnlyOnError "{{ unattended_upgrades_mail_only_on_error | string | lower }}";
{% endif %}
{% endif %}
{% if unattended_upgrades_blacklist_merged | default([]) | length > 0 %}

Unattended-Upgrade::Package-Blacklist {
{% for pkg in unattended_upgrades_blacklist_merged | default([]) %}
    "{{ pkg }}";
{% endfor %}
};
{% endif %}
